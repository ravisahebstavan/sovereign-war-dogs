# ── Finnhub ───────────────────────────────────────────────────────────────────
# Free API key — sign up at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Free paper trading account — sign up at https://alpaca.markets
# Enable paper trading in the dashboard, copy your paper API keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Default: local Redis on port 6379
# Install: winget install Redis.Redis  (Windows)
#          brew install redis           (macOS)
#          apt install redis-server     (Linux)
REDIS_URL=redis://127.0.0.1:6379

# ── Rust logging ─────────────────────────────────────────────────────────────
RUST_LOG=sovereign_core=info,tower_http=warn
